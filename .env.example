# ─── POURSONA ENVIRONMENT VARIABLES ───────────────────────────────────────────
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub — it's already in .gitignore

# ── ANTHROPIC ──────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── SUPABASE ───────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # Never expose this publicly

# ── STRIPE (add when ready for billing) ────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── APP ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000  # Change to your domain in production
APP_SECRET=your-random-secret-string-here  # Generate: openssl rand -hex 32
